% Harvested example for Range
% src: lib/sli/mathematica.sli:935
% summary: Generate array with range of numbers
% synopsis: [N] Range  -> [1 ... N] [N1 N2] Range -> [N1 ... N2] [N1 N2 d] Range -> [N1 N1+d N1+2d ...]
%
% Examples (verbatim from docstring):
%             [5] Range    -> [1 2 3 4 5]
%           [2 5] Range    -> [2 3 4 5]
%           [5 2] Range    -> []
%           [5 2 -1] Range -> [5 4 3 2]
%           [1.0 10.0 2.5] Range -> [1 3.5 6 8.5]
