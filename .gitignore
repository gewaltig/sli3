# Build artefacts (root-anchored so they don't shadow lib/sli/)
*.o
*.a
*.dylib
*.so
/sli
/sli3
/test_*

# Editor backups
*~
*.swp
.DS_Store

# Local Claude Code settings
.claude/

# CMake (root-anchored to catch accidental in-source builds; out-of-source
# builds in build/ are also covered by build/ below). /Makefile is NOT
# ignored — the repo ships a hand-written convenience Makefile that wraps
# cmake; in-source CMake builds (which would overwrite it) are blocked
# by the guard in CMakeLists.txt.
build/
build-*/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/CTestTestfile.cmake
/config.h
/compile_commands.json

# Benchmark results DB (per-machine; regenerate baseline via
# bench/init_db.sh)
bench/results.db
bench/results.db-journal
bench/results.db-wal
bench/results.db-shm
